# Password protecting the local PKCS12 keystore/truststore files generated by
# cert-manager below. This is not an application secret — it only guards a
# file on disk inside the pod — so a fixed, shared value is fine for this
# test setup.
apiVersion: v1
kind: Secret
metadata:
  name: client-keystore-password
  namespace: mq-test
type: Opaque
stringData:
  password: <KEYSTORE_PASSWORD>
---
apiVersion: v1
kind: Secret
metadata:
  name: server-truststore-password
  namespace: mq-test
type: Opaque
stringData:
  password: <TRUSTSTORE_PASSWORD>
